{
  "version": 1,
  "httpServers": {
    "moxy": {
      "command": "@MOXY@",
      "args": [
        "serve",
        "http"
      ],
      "transport": "streamable-http",
      "timeout": 300000,
      "healthcheck": {
        "path": "/healthz",
        "interval": "1s",
        "timeout": "30s"
      }
    }
  }
}
