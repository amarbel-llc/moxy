#!/usr/bin/env bash
set -euo pipefail
jql="$1"
fields="${2:-issuetype,key,assignee,priority,status,summary}"
limit="${3:-50}"
output_format="${4:-}"
args=(jira workitem search --jql "$jql" --fields "$fields" --limit "$limit")
if [ "$output_format" = "json" ]; then args+=(--json); mime="application/json"; else mime="text/plain"; fi
output=$(acli "${args[@]}")
jq -cn --arg text "$output" --arg mime "$mime" '{content:[{type:"text",text:$text,mimeType:$mime}]}'
