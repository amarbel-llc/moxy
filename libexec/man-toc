#!/usr/bin/env bash
set -euo pipefail

page="$1"
src=$(man -w "$page" 2>/dev/null) || true
src="${src%%$'\n'*}"

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
raw=$(case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac)
# pandoc reads groff man macros directly; mandoc -T man converts mdoc→man first
md=$(echo "$raw" | pandoc -f man -t markdown 2>/dev/null)
if ! grep -q '^#' <<< "$md"; then
  md=$(echo "$raw" | mandoc -T man 2>/dev/null | pandoc -f man -t markdown 2>/dev/null)
fi
echo "$md" | awk '/^#+ /{print}'
