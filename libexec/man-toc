#!/usr/bin/env bash
set -euo pipefail

page="$1"
src=$(MANPATH=$(manpath 2>/dev/null) man -w "$page" 2>/dev/null | head -1)

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac | mandoc -T man 2>/dev/null | pandoc -f man -t markdown 2>/dev/null | awk '/^#+ /{print}'
