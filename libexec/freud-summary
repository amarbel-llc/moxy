#!/usr/bin/env python3

import json
import os
import sys
from collections import Counter
from pathlib import Path


def find_session(session_id: str) -> tuple[Path | None, str]:
    """Returns (jsonl_path, project_cwd)."""
    projects_dir = Path(os.environ.get(
        "CLAUDE_PROJECTS_DIR", Path.home() / ".claude" / "projects"
    ))
    if not projects_dir.is_dir():
        return None, ""
    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir():
            continue
        f = proj_dir / f"{session_id}.jsonl"
        if f.exists():
            return f, proj_dir.name
    return None, ""


def resolve_cwd(path: Path) -> str:
    with open(path) as f:
        for i, line in enumerate(f):
            if i >= 200:
                break
            try:
                obj = json.loads(line)
                cwd = obj.get("cwd")
                if cwd:
                    return cwd
            except (json.JSONDecodeError, KeyError):
                continue
    return "(unknown)"


def truncate(s: str, max_len: int) -> str:
    s = s.replace("\n", " ").strip()
    if len(s) > max_len:
        return s[:max_len] + "..."
    return s


def main():
    session_id = sys.argv[1] if len(sys.argv) > 1 else ""

    if not session_id:
        print("Usage: freud-summary <session_id>", file=sys.stderr)
        sys.exit(1)

    path, _ = find_session(session_id)
    if path is None:
        print(f"Session {session_id} not found. Use the sessions tool to list available sessions.")
        sys.exit(1)

    project = resolve_cwd(path)

    user_count = 0
    assistant_count = 0
    other_count = 0
    interrupt_count = 0
    reject_count = 0
    tool_counter: Counter = Counter()
    user_prompts: list[str] = []
    first_ts = ""
    last_ts = ""

    with open(path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            ts = obj.get("timestamp", "")
            if ts:
                if not first_ts:
                    first_ts = ts
                last_ts = ts

            msg_type = obj.get("type")
            if msg_type == "user":
                user_count += 1

                # Count rejections from top-level toolUseResult
                if obj.get("toolUseResult") == "User rejected tool use":
                    reject_count += 1

                content = obj.get("message", {}).get("content")
                if isinstance(content, str):
                    if content.strip():
                        user_prompts.append(content.strip())
                    if content.startswith("[Request interrupted by user"):
                        interrupt_count += 1
                elif isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "text":
                            text = block.get("text", "")
                            if text.startswith("[Request interrupted by user"):
                                interrupt_count += 1
            elif msg_type == "assistant":
                assistant_count += 1
                content = obj.get("message", {}).get("content")
                if isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "tool_use":
                            tool_counter[block.get("name", "?")] += 1
            else:
                other_count += 1

    # Format timestamps
    def fmt_ts(ts: str) -> str:
        if not ts:
            return "?"
        return ts.replace("T", " ").split(".")[0].replace("Z", " UTC")

    lines = []
    lines.append(f"Session: {session_id}")
    lines.append(f"Project: {project}")
    lines.append(f"Duration: {fmt_ts(first_ts)} → {fmt_ts(last_ts)}")
    lines.append(f"Messages: {user_count} user / {assistant_count} assistant / {other_count} other")
    if interrupt_count > 0 or reject_count > 0:
        lines.append(f"Interruptions: {interrupt_count} interrupted / {reject_count} rejected")

    if tool_counter:
        lines.append(f"\nTop tools ({len(tool_counter)} distinct):")
        for name, count in tool_counter.most_common(20):
            lines.append(f"  {name}: {count}")

    if user_prompts:
        lines.append(f"\nUser prompts ({len(user_prompts)}):")
        for i, prompt in enumerate(user_prompts, start=1):
            lines.append(f"  [{i}] {truncate(prompt, 120)}")

    emit_mcp_result("\n".join(lines))


def emit_mcp_result(text: str, mime: str = "text/plain"):
    result = {"content": [{"type": "text", "text": text, "mimeType": mime}]}
    print(json.dumps(result))


if __name__ == "__main__":
    main()
