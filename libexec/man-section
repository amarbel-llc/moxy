#!/usr/bin/env bash
set -euo pipefail

page="$1"; section_name="$2"
src=$(MANPATH=$(manpath 2>/dev/null) man -w "$page" 2>/dev/null | head -1)

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
rendered=$(case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac | mandoc -T man 2>/dev/null | pandoc -f man -t markdown 2>/dev/null)
result=$(echo "$rendered" | awk -v target="$section_name" '
BEGIN { found=0; IGNORECASE=1 }
/^#+ / {
  if (found) exit
  name = $0; sub(/^#+ /, "", name)
  if (tolower(name) == tolower(target)) found=1
}
found { print }
')
if [ -z "$result" ]; then
  echo "Section \"$section_name\" not found in $page. Available sections:"
  echo "$rendered" | awk '/^#+ /{print}'
  exit 1
fi
echo "$result"
