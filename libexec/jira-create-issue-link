#!/usr/bin/env bash
set -euo pipefail
link_type="$1"
outward_issue="$2"
inward_issue="$3"
output_format="${4:-}"
args=(jira workitem link "$outward_issue" "$inward_issue" --type "$link_type")
if [ "$output_format" = "json" ]; then args+=(--json); mime="application/json"; else mime="text/plain"; fi
output=$(acli "${args[@]}")
jq -cn --arg text "$output" --arg mime "$mime" '{content:[{type:"text",text:$text,mimeType:$mime}]}'
