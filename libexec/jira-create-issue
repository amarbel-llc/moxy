#!/usr/bin/env bash
set -euo pipefail
project="$1"
summary="$2"
description="${3:-}"
issuetype="${4:-Task}"
priority="${5:-}"
labels="${6:-}"
assignee="${7:-}"
parent="${8:-}"
output_format="${9:-}"
args=(jira workitem create --project "$project" --summary "$summary" --type "$issuetype")
[ -n "$description" ] && args+=(--description "$description")
[ -n "$priority" ] && args+=(--priority "$priority")
[ -n "$labels" ] && args+=(--labels "$labels")
[ -n "$assignee" ] && args+=(--assignee "$assignee")
[ -n "$parent" ] && args+=(--parent "$parent")
[ "$output_format" = "json" ] && args+=(--json)
acli "${args[@]}"
