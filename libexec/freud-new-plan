#!/usr/bin/env python3

import sys
from pathlib import Path


def main():
    if len(sys.argv) < 3:
        print("Usage: freud-new-plan <name> <content>", file=sys.stderr)
        sys.exit(1)

    name = sys.argv[1]
    content = sys.argv[2]

    plans_dir = Path.home() / ".claude" / "plans"
    plans_dir.mkdir(parents=True, exist_ok=True)

    plan_path = plans_dir / f"{name}.md"

    if plan_path.exists():
        print(f"Error: plan already exists: {plan_path}", file=sys.stderr)
        sys.exit(1)

    plan_path.write_text(content)
    print(plan_path)


if __name__ == "__main__":
    main()
