#!/usr/bin/env python3

import json
import os
import sys
import time
from collections import Counter
from datetime import datetime, timezone
from pathlib import Path


def resolve_cwd(proj_dir: Path) -> str | None:
    """Extract cwd from the newest JSONL in a project directory."""
    jsonls = sorted(proj_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not jsonls:
        return None

    with open(jsonls[0]) as f:
        for i, line in enumerate(f):
            if i >= 200:
                break
            try:
                obj = json.loads(line)
                cwd = obj.get("cwd")
                if cwd:
                    return cwd
            except (json.JSONDecodeError, KeyError):
                continue

    name = proj_dir.name.lstrip("-")
    return "/" + name.replace("-", "/") + " (heuristic)"


def matches_project(resolved_cwd: str, dir_name: str, filter_str: str) -> bool:
    lower = filter_str.lower()
    return lower in resolved_cwd.lower() or lower in dir_name.lower()


def truncate(s: str, max_len: int) -> str:
    s = s.replace("\n", " ").strip()
    if len(s) > max_len:
        return s[:max_len] + "..."
    return s


def collect_failures(path: Path, tool_name_filter: str) -> list[dict]:
    """Extract tool results that are errors or have empty content."""
    # Build a map from tool_use_id -> tool name from assistant messages
    tool_names: dict[str, str] = {}
    # Collect tool_result blocks from user messages
    failures: list[dict] = []

    with open(path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            msg_type = obj.get("type")
            content = obj.get("message", {}).get("content")
            if not isinstance(content, list):
                continue

            if msg_type == "assistant":
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_use":
                        tool_names[block.get("id", "")] = block.get("name", "?")

            elif msg_type == "user":
                for block in content:
                    if not isinstance(block, dict) or block.get("type") != "tool_result":
                        continue

                    tool_use_id = block.get("tool_use_id", "")
                    is_error = block.get("is_error", False)
                    inner = block.get("content", "")

                    # Extract text from content
                    if isinstance(inner, list):
                        text = " ".join(
                            b.get("text", "")
                            for b in inner
                            if isinstance(b, dict) and b.get("type") == "text"
                        ).strip()
                    elif isinstance(inner, str):
                        text = inner.strip()
                    else:
                        text = str(inner).strip()

                    is_empty = not text

                    if not is_error and not is_empty:
                        continue

                    name = tool_names.get(tool_use_id, "?")

                    if tool_name_filter and tool_name_filter.lower() not in name.lower():
                        continue

                    failures.append({
                        "tool": name,
                        "is_error": is_error,
                        "is_empty": is_empty,
                        "preview": truncate(text, 120) if text else "(empty)",
                    })

    return failures


def subagent_paths(session_path: Path) -> list[Path]:
    """Return subagent JSONL paths for a session, if any."""
    sub_dir = session_path.parent / session_path.stem / "subagents"
    if sub_dir.is_dir():
        return list(sub_dir.glob("*.jsonl"))
    return []


def main():
    project_filter = sys.argv[1] if len(sys.argv) > 1 else ""
    days = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2] else 7
    tool_name_filter = sys.argv[3] if len(sys.argv) > 3 else ""
    limit = int(sys.argv[4]) if len(sys.argv) > 4 and sys.argv[4] else 30

    projects_dir = Path(os.environ.get(
        "CLAUDE_PROJECTS_DIR", Path.home() / ".claude" / "projects"
    ))
    if not projects_dir.is_dir():
        return emit_mcp_result("(no sessions found)")

    cutoff = time.time() - (days * 86400)

    # Phase 1: resolve cwd per project directory
    cwd_map: dict[str, str] = {}
    for proj_dir in sorted(projects_dir.iterdir()):
        if not proj_dir.is_dir():
            continue
        cwd = resolve_cwd(proj_dir)
        if cwd:
            cwd_map[proj_dir.name] = cwd

    # Phase 2: collect matching session files
    session_paths: list[Path] = []
    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir() or proj_dir.name not in cwd_map:
            continue
        project = cwd_map[proj_dir.name]
        if project_filter and not matches_project(project, proj_dir.name, project_filter):
            continue
        for f in proj_dir.glob("*.jsonl"):
            if f.stat().st_mtime >= cutoff:
                session_paths.append(f)

    if not session_paths:
        return emit_mcp_result(f"No sessions found (days={days}, project={project_filter or 'all'})")

    # Phase 3: collect failures across all sessions (including subagents)
    all_failures: list[dict] = []
    for path in session_paths:
        all_failures.extend(collect_failures(path, tool_name_filter))
        for sub in subagent_paths(path):
            all_failures.extend(collect_failures(sub, tool_name_filter))

    if not all_failures:
        filter_desc = f", tool={tool_name_filter}" if tool_name_filter else ""
        return emit_mcp_result(
            f"No failed or empty tool results across {len(session_paths)} sessions{filter_desc}"
        )

    # Phase 4: aggregate by tool name and failure type
    error_counter: Counter = Counter()
    empty_counter: Counter = Counter()
    example_previews: dict[str, str] = {}

    for f in all_failures:
        tool = f["tool"]
        if f["is_error"]:
            error_counter[tool] += 1
        if f["is_empty"]:
            empty_counter[tool] += 1
        if tool not in example_previews:
            example_previews[tool] = f["preview"]

    # Combine and sort by total failures
    all_tools = set(error_counter.keys()) | set(empty_counter.keys())
    ranked = sorted(
        all_tools,
        key=lambda t: error_counter[t] + empty_counter[t],
        reverse=True,
    )

    if limit > 0:
        ranked = ranked[:limit]

    # Phase 5: format output
    lines = []
    proj_desc = f", project: {project_filter}" if project_filter else ""
    tool_desc = f", tool: {tool_name_filter}" if tool_name_filter else ""
    lines.append(f"Tool result failures across {len(session_paths)} sessions ({days} days{proj_desc}{tool_desc})")
    lines.append(f"Total: {len(all_failures)} failures ({sum(error_counter.values())} errors, {sum(empty_counter.values())} empty)")

    max_name = max(4, max(len(t) for t in ranked))

    lines.append("")
    lines.append(f"  {'#':>3}  {'Tool':<{max_name}}  {'Errors':>6}  {'Empty':>5}  Example")
    for i, tool in enumerate(ranked, start=1):
        errs = error_counter[tool]
        empties = empty_counter[tool]
        preview = example_previews.get(tool, "")
        lines.append(f"  {i:>3}  {tool:<{max_name}}  {errs:>6}  {empties:>5}  {preview}")

    # Date range
    mtimes = [p.stat().st_mtime for p in session_paths]
    earliest = datetime.fromtimestamp(min(mtimes), tz=timezone.utc).strftime("%Y-%m-%d")
    latest = datetime.fromtimestamp(max(mtimes), tz=timezone.utc).strftime("%Y-%m-%d")
    lines.append(f"\n{len(session_paths)} sessions analyzed ({earliest} \u2192 {latest})")

    emit_mcp_result("\n".join(lines))


def emit_mcp_result(text: str, mime: str = "text/plain"):
    result = {"content": [{"type": "text", "text": text, "mimeType": mime}]}
    print(json.dumps(result))


if __name__ == "__main__":
    main()
