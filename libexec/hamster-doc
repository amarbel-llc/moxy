#!/usr/bin/env bash
set -euo pipefail
pkg="$1"

# Auto-detect local packages: rewrite module prefix to ./
mod=$(go list -m 2>/dev/null) || mod=""
if [ -n "$mod" ] && [ "$pkg" != "$mod" ]; then
  case "$pkg" in
    "$mod"/*) pkg="./${pkg#"$mod"/}" ;;
  esac
fi

if [ -n "${2:-}" ]; then
  go doc -all "$pkg.$2"
else
  go doc -all "$pkg"
fi
