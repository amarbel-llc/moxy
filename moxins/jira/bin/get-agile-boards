#!/usr/bin/env bash
set -euo pipefail
project="${1:-}"
name="${2:-}"
max_results="${3:-50}"
output_format="${4:-}"
args=(jira board search --limit "$max_results")
[ -n "$project" ] && args+=(--project "$project")
[ -n "$name" ] && args+=(--name "$name")
if [ "$output_format" = "json" ]; then args+=(--json); mime="application/json"; else mime="text/plain"; fi
output=$(acli "${args[@]}")
jq -cn --arg text "$output" --arg mime "$mime" '{content:[{type:"text",text:$text,mimeType:$mime}]}'
