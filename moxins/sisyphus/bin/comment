#!/usr/bin/env python3
import os
import sys

sys.path.insert(
    0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib")
)
import _lib

issue_key = sys.argv[1]
body = sys.argv[2]
output_format = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""

jira = _lib.make_client()
# v3 issue_add_comment posts {"body": comment} where comment is wiki markup on
# v2 but ADF JSON on v3. The atlassian SDK doesn't transform it for us — we
# must hand it pre-converted.
with _lib.jira_call():
    result = jira.issue_add_comment(issue_key, _lib.md_to_adf(body))

url = _lib.browse_url(jira, issue_key)
if output_format == "json":
    if url:
        result = {**result, "browse_url": url}
    _lib.emit(result)
else:
    line = f"Comment added to {issue_key}"
    if url:
        line += f"\n{url}"
    _lib.emit(line)
