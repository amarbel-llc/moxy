#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

link_type = sys.argv[1]
outward_issue = sys.argv[2]
inward_issue = sys.argv[3]
output_format = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else ""

jira = _lib.make_client()
result = jira.create_issue_link({
    "type": {"name": link_type},
    "outwardIssue": {"key": outward_issue},
    "inwardIssue": {"key": inward_issue},
})

if output_format == "json":
    _lib.emit(result if result else {"status": "linked"})
else:
    _lib.emit(f"Linked {outward_issue} -> {inward_issue} ({link_type})")
