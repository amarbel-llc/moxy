#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

project = sys.argv[1]
summary = sys.argv[2]
description = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""
issuetype = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else "Task"
priority = sys.argv[5] if len(sys.argv) > 5 and sys.argv[5] else ""
labels = sys.argv[6] if len(sys.argv) > 6 and sys.argv[6] else ""
assignee = sys.argv[7] if len(sys.argv) > 7 and sys.argv[7] else ""
parent = sys.argv[8] if len(sys.argv) > 8 and sys.argv[8] else ""
output_format = sys.argv[9] if len(sys.argv) > 9 and sys.argv[9] else ""

fields = {
    "project": {"key": project},
    "summary": summary,
    "issuetype": {"name": issuetype},
}
if description:
    fields["description"] = _lib.md_to_adf(description)
if priority:
    fields["priority"] = {"name": priority}
if labels:
    parsed = _lib.parse_argv_list(labels)
    if isinstance(parsed, list):
        fields["labels"] = [str(l).strip() for l in parsed]
    else:
        fields["labels"] = [l.strip() for l in parsed.split(",")]
if assignee:
    if assignee == "@me":
        jira = _lib.make_client()
        me = jira.myself()
        fields["assignee"] = {"accountId": me["accountId"]}
    else:
        fields["assignee"] = {"id": assignee}
if parent:
    fields["parent"] = {"key": parent}

jira = _lib.make_client()
result = jira.create_issue(fields=fields)

if output_format == "json":
    _lib.emit(result)
else:
    _lib.emit(f"Created {result.get('key', 'unknown')}: {summary}")
