#!/usr/bin/env python3
import os
import sys

sys.path.insert(
    0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib")
)
import _lib

issue_key = sys.argv[1]
summary = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else ""
description = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""
assignee = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else ""
labels = sys.argv[5] if len(sys.argv) > 5 and sys.argv[5] else ""
issuetype = sys.argv[6] if len(sys.argv) > 6 and sys.argv[6] else ""
output_format = sys.argv[7] if len(sys.argv) > 7 and sys.argv[7] else ""

fields = {}
if summary:
    fields["summary"] = summary
if description:
    fields["description"] = _lib.md_to_adf(description)
if labels:
    parsed = _lib.parse_argv_list(labels)
    if isinstance(parsed, list):
        fields["labels"] = [str(label).strip() for label in parsed]
    else:
        fields["labels"] = [label.strip() for label in parsed.split(",")]
if issuetype:
    fields["issuetype"] = {"name": issuetype}

if not fields and not assignee:
    _lib.emit(f"No fields to update on {issue_key}")
    sys.exit(0)

jira = _lib.make_client()
if assignee:
    # v3's fields.assignee documents the JSON key as `id` (with the value
    # being an accountId). The dedicated /assignee endpoint uses `accountId`,
    # but that's a different path. See:
    # https://developer.atlassian.com/cloud/jira/platform/deprecation-notice-user-privacy-api-migration-guide/#issue
    fields["assignee"] = {"id": _lib.resolve_assignee(jira, assignee)}
with _lib.jira_call():
    jira.update_issue_field(issue_key, fields)

if output_format == "json":
    _lib.emit(_lib.render_issue_body_fields(jira.get_issue(issue_key)))
else:
    _lib.emit(f"Updated {issue_key}")
