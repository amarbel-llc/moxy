#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

issue_key = sys.argv[1]
fields = _lib.parse_argv_list(sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None)
output_format = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""

jira = _lib.make_client()
result = _lib.render_issue_body_fields(jira.get_issue(issue_key, fields=fields))

if output_format == "json":
    _lib.emit(result)
else:
    f = result.get("fields", {})
    lines = [
        f"{result['key']}: {f.get('summary', '')}",
        f"Status: {(f.get('status') or {}).get('name', '')}",
        f"Type: {(f.get('issuetype') or {}).get('name', '')}",
        f"Priority: {(f.get('priority') or {}).get('name', '')}",
        f"Assignee: {(f.get('assignee') or {}).get('displayName', 'Unassigned')}",
    ]
    desc = f.get("description", "")
    if desc:
        lines.append(f"\n{desc}")
    _lib.emit("\n".join(lines))
