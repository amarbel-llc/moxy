#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

issue_key = sys.argv[1]
status = sys.argv[2]
output_format = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""

jira = _lib.make_client()
jira.set_issue_status(issue_key, status)

if output_format == "json":
    _lib.emit(_lib.render_issue_body_fields(jira.get_issue(issue_key)))
else:
    _lib.emit(f"Transitioned {issue_key} to {status}")
