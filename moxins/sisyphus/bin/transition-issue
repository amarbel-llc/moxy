#!/usr/bin/env python3
import os
import sys

sys.path.insert(
    0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib")
)
import _lib

issue_key = sys.argv[1]
status = sys.argv[2]
output_format = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""

jira = _lib.make_client()
jira.set_issue_status(issue_key, status)

url = _lib.browse_url(jira, issue_key)
if output_format == "json":
    result = _lib.render_issue_body_fields(jira.get_issue(issue_key))
    if url:
        result = {**result, "browse_url": url}
    _lib.emit(result)
else:
    line = f"Transitioned {issue_key} to {status}"
    if url:
        line += f"\n{url}"
    _lib.emit(line)
