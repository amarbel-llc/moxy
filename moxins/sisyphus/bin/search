#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

jql = sys.argv[1]
fields = _lib.parse_argv_list(
    sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else "issuetype,key,assignee,priority,status,summary"
)
max_results = int(sys.argv[3]) if len(sys.argv) > 3 and sys.argv[3] else 50
output_format = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else ""

jira = _lib.make_client()
result = jira.jql(jql, fields=fields, limit=max_results)

if isinstance(result, dict) and isinstance(result.get("issues"), list):
    result["issues"] = [_lib.render_issue_body_fields(i) for i in result["issues"]]

if output_format == "json":
    _lib.emit(result)
else:
    issues = result.get("issues", [])
    # v3's /search/jql endpoint returns no `total` — only `isLast` and a
    # `nextPageToken` for paging. Adapt the header to whichever shape we
    # got back so we don't claim "Found 50 issues" when really we just
    # returned 50 of an unknown-larger total.
    total = result.get("total")
    is_last = result.get("isLast")
    if total is not None:
        header = f"Found {total} issues"
    elif is_last is False:
        header = f"Returned {len(issues)} issues (more available — pass a higher max_results to see them)"
    else:
        header = f"Returned {len(issues)} issues"
    lines = [header + "\n"]
    for issue in issues:
        f = issue.get("fields", {})
        status = (f.get("status") or {}).get("name", "")
        assignee = (f.get("assignee") or {}).get("displayName", "Unassigned")
        lines.append(f"{issue['key']}  {status:15s}  {assignee:20s}  {f.get('summary', '')}")
    _lib.emit("\n".join(lines))
