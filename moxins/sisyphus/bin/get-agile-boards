#!/usr/bin/env python3
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import _lib

project = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] else None
name = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None
max_results = int(sys.argv[3]) if len(sys.argv) > 3 and sys.argv[3] else 50
output_format = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else ""

jira = _lib.make_client()
result = jira.get_all_agile_boards(
    board_name=name,
    project_key=project,
    limit=max_results,
)

if output_format == "json":
    _lib.emit(result)
else:
    boards = result.get("values", [])
    lines = [f"Found {len(boards)} boards\n"]
    for b in boards:
        loc = b.get("location", {})
        proj = loc.get("projectName", "") if loc else ""
        lines.append(f"  {b['id']:>6}  {b.get('name', ''):30s}  {b.get('type', ''):10s}  {proj}")
    _lib.emit("\n".join(lines))
