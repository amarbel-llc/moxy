#!/usr/bin/env bash
set -euo pipefail
pattern="$1"
path="${2:-.}"
glob="${3:-}"
filetype="${4:-}"
output_mode="${5:-files_with_matches}"
context="${6:-}"
case_insensitive="${7:-}"
multiline="${8:-}"

rg_args=()

case "$output_mode" in
  files_with_matches) rg_args+=(-l) ;;
  count)              rg_args+=(-c) ;;
  content)            rg_args+=(-n) ;;
  *) echo "Unknown output_mode: $output_mode" >&2; exit 1 ;;
esac

# Split a glob string on top-level commas (commas outside {...}) so the
# intuitive comma form `*.sh,*.bash` becomes multiple --glob args, while a
# brace glob `*.{sh,bash}` is preserved as a single glob. See #289.
if [ -n "$glob" ]; then
  depth=0
  piece=""
  for (( i=0; i<${#glob}; i++ )); do
    ch="${glob:i:1}"
    case "$ch" in
      '{')
        depth=$((depth + 1))
        piece+="$ch"
        ;;
      '}')
        if [ "$depth" -gt 0 ]; then
          depth=$((depth - 1))
        fi
        piece+="$ch"
        ;;
      ',')
        if [ "$depth" -eq 0 ]; then
          if [ -n "$piece" ]; then
            rg_args+=(--glob "$piece")
          fi
          piece=""
        else
          piece+="$ch"
        fi
        ;;
      *) piece+="$ch" ;;
    esac
  done
  if [ -n "$piece" ]; then
    rg_args+=(--glob "$piece")
  fi
fi

[ -n "$filetype" ] && rg_args+=(--type "$filetype")

[ -n "$context" ] && rg_args+=(-C "$context")

[ "$case_insensitive" = "true" ] && rg_args+=(-i)

[ "$multiline" = "true" ] && rg_args+=(-U --multiline-dotall)

output=$(rg "${rg_args[@]}" -- "$pattern" "$path" 2>&1) || true

printf '%s\n' "$output"
