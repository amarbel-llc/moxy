#!/usr/bin/env bash
set -euo pipefail
pattern="$1"
path="${2:-.}"
glob="${3:-}"
filetype="${4:-}"
output_mode="${5:-files_with_matches}"
context="${6:-}"
case_insensitive="${7:-}"
multiline="${8:-}"

rg_args=()

case "$output_mode" in
  files_with_matches) rg_args+=(-l) ;;
  count)              rg_args+=(-c) ;;
  content)            rg_args+=(-n) ;;
  *) echo "Unknown output_mode: $output_mode" >&2; exit 1 ;;
esac

[ -n "$glob" ] && rg_args+=(--glob "$glob")

[ -n "$filetype" ] && rg_args+=(--type "$filetype")

[ -n "$context" ] && rg_args+=(-C "$context")

[ "$case_insensitive" = "true" ] && rg_args+=(-i)

[ "$multiline" = "true" ] && rg_args+=(-U --multiline-dotall)

output=$(rg "${rg_args[@]}" -- "$pattern" "$path" 2>&1) || true

printf '%s\n' "$output"
