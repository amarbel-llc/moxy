#!/usr/bin/env bash
set -euo pipefail
pattern="$1"
path="${2:-.}"
glob="${3:-}"
filetype="${4:-}"
output_mode="${5:-files_with_matches}"
context="${6:-}"
case_insensitive="${7:-}"
multiline="${8:-}"
hidden="${9:-}"

rg_args=()

case "$output_mode" in
  files_with_matches) rg_args+=(-l) ;;
  count)              rg_args+=(-c) ;;
  content)            rg_args+=(-n) ;;
  *) echo "Unknown output_mode: $output_mode" >&2; exit 1 ;;
esac

# Split a glob string on top-level commas (commas outside {...}) so the
# intuitive comma form `*.sh,*.bash` becomes multiple --glob args, while a
# brace glob `*.{sh,bash}` is preserved as a single glob. See #289.
if [ -n "$glob" ]; then
  depth=0
  piece=""
  for (( i=0; i<${#glob}; i++ )); do
    ch="${glob:i:1}"
    case "$ch" in
      '{')
        depth=$((depth + 1))
        piece+="$ch"
        ;;
      '}')
        if [ "$depth" -gt 0 ]; then
          depth=$((depth - 1))
        fi
        piece+="$ch"
        ;;
      ',')
        if [ "$depth" -eq 0 ]; then
          if [ -n "$piece" ]; then
            rg_args+=(--glob "$piece")
          fi
          piece=""
        else
          piece+="$ch"
        fi
        ;;
      *) piece+="$ch" ;;
    esac
  done
  if [ -n "$piece" ]; then
    rg_args+=(--glob "$piece")
  fi
fi

[ -n "$filetype" ] && rg_args+=(--type "$filetype")

[ -n "$context" ] && rg_args+=(-C "$context")

[ "$case_insensitive" = "true" ] && rg_args+=(-i)

[ "$multiline" = "true" ] && rg_args+=(-U --multiline-dotall)

# --hidden searches dotfiles/dot-directories (e.g. .github/) that ripgrep
# skips by default. .gitignore is still honored, so .git/ stays excluded.
# See #285.
[ "$hidden" = "true" ] && rg_args+=(--hidden)

# ripgrep exit codes: 0 = match, 1 = no match (clean), 2 = error. Capture
# combined stdout+stderr and branch on the exit code so a real error (bad
# regex, unrecognized --type, unreadable path) is surfaced as a tool error
# (non-zero exit -> isError result) instead of being swallowed and read as an
# empty "no matches" success. See #296. On a clean run rg writes nothing to
# stderr, so the combined capture holds only matches.
set +e
output=$(rg "${rg_args[@]}" -- "$pattern" "$path" 2>&1)
rc=$?
set -e

case "$rc" in
  0|1)
    # Match (0) or clean no-match (1). Empty output is a genuine absence.
    printf '%s\n' "$output"
    ;;
  *)
    # rg reported an error; surface it.
    printf '%s\n' "${output:-rg exited with status $rc}" >&2
    exit "$rc"
    ;;
esac
