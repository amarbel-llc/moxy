#!/usr/bin/env bash
set -euo pipefail
ref="${1:-}"
repo_owner_name="${2:-}"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  user=$(gh api /user --jq '.login')
  name=$(gh repo view --json name --jq '.name')
  repo="$user/$name"
fi

# Default to the repo's default branch when no ref given
if [ -z "$ref" ]; then
  ref=$(gh api "repos/$repo" --jq '.default_branch')
fi

# Resolve ref to tree SHA via commits endpoint
tree_sha=$(gh api "repos/$repo/commits/$ref" --jq '.commit.tree.sha')

gh api "repos/$repo/git/trees/$tree_sha?recursive=1" \
  | jq '[.tree[] | {path, type, size}]'
