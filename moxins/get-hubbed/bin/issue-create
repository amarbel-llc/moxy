#!/usr/bin/env bash
set -euo pipefail
title="$1"
body="${2:-}"
labels_json="${3:-}"
repo_owner_name="${4:-}"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  user=$(gh api /user --jq '.login')
  name=$(gh repo view --json name --jq '.name')
  repo="$user/$name"
fi

gh_args=(issue create -R "$repo" --title "$title")

[ -n "$body" ] && gh_args+=(--body "$body")
if [ -n "$labels_json" ] && [ "$labels_json" != "null" ]; then
  while IFS= read -r label; do
    gh_args+=(--label "$label")
  done < <(printf '%s' "$labels_json" | jq -r '.[]')
fi
gh "${gh_args[@]}"
