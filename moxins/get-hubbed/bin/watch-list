#!/usr/bin/env bash
set -euo pipefail

dir="${MOXY_GH_WATCH_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/moxy/gh-watch}"
targets="$dir/targets"

if [ ! -s "$targets" ]; then
  echo "(no gh-watch targets)"
  exit 0
fi

printf '%-40s  %-12s  %-12s  %s\n' HANDLE STATUS CONCLUSION AGE
while IFS=$'\t' read -r kind repo id handle added; do
  [ -z "$kind" ] && continue
  case "$kind" in
    run)
      json=$(gh api "repos/$repo/actions/runs/$id" \
        --jq '{status, conclusion}' 2>/dev/null || echo '{}')
      status=$(printf '%s' "$json" | jq -r '.status // "?"')
      conclusion=$(printf '%s' "$json" | jq -r '.conclusion // "-"')
      ;;
    *)
      status="?"
      conclusion="-"
      ;;
  esac
  printf '%-40s  %-12s  %-12s  (added %s)\n' "$handle" "$status" "$conclusion" "$added"
done <"$targets"
