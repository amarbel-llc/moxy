#!/usr/bin/env bash
set -euo pipefail
filename="$1"
content="$2"
description="${3:-}"
public="${4:-}"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
printf '%s' "$content" > "$tmpdir/$filename"

gh_args=(gist create "$tmpdir/$filename")
[ -n "$description" ] && gh_args+=(--desc "$description")
[ "$public" = "true" ] && gh_args+=(--public)
gh "${gh_args[@]}"
