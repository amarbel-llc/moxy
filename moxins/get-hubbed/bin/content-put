#!/usr/bin/env bash
set -euo pipefail
# Content arrives on STDIN (stdin-param in content-put.toml), never argv:
# argv would cap it at Linux's per-arg exec limit (MAX_ARG_STRLEN, #342) —
# once at moxy's exec of this script and again at the jq below. Stdin is
# consumed only by that jq (-Rs), preserving content byte-identically
# (including trailing newlines a $(cat) capture would strip).
path="$1"
message="$2"
branch="${3:-}"
repo_owner_name="${4:-}"

# shellcheck source=bin/.resolve-repo
. "$(dirname "$0")/.resolve-repo"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  repo=$(resolve_repo_from_origin)
fi

gh_args=(api "repos/$repo/contents/$path" --method PUT --input -)

# Build the request body. Fetch existing file sha for updates. The explicit
# --method GET matters: `gh api` switches to POST whenever -f fields are
# present, so without it the ref-scoped lookup silently failed and updates on
# non-default branches went out sha-less → 422 (#306). With --method GET the
# field is sent as a ?ref= query parameter instead.
sha=""
if existing=$(gh api "repos/$repo/contents/$path" --method GET ${branch:+-f ref="$branch"} 2>/dev/null); then
  sha=$(printf '%s' "$existing" | jq -r '.sha // empty')
fi

body=$(jq -Rs \
  --arg message "$message" \
  --arg sha "$sha" \
  --arg branch "$branch" \
  '{message: $message, content: (. | @base64)}
   + (if $sha != "" then {sha: $sha} else {} end)
   + (if $branch != "" then {branch: $branch} else {} end)')

printf '%s' "$body" | gh "${gh_args[@]}"
