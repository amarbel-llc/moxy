#!/usr/bin/env bash
set -euo pipefail
path="$1"
content="$2"
message="$3"
branch="${4:-}"
repo_owner_name="${5:-}"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  user=$(gh api /user --jq '.login')
  name=$(gh repo view --json name --jq '.name')
  repo="$user/$name"
fi

gh_args=(api "repos/$repo/contents/$path" --method PUT --input -)

# Build the request body. Fetch existing file sha for updates.
sha=""
if existing=$(gh api "repos/$repo/contents/$path" ${branch:+-f ref="$branch"} 2>/dev/null); then
  sha=$(printf '%s' "$existing" | jq -r '.sha // empty')
fi

body=$(jq -n \
  --arg message "$message" \
  --arg content "$content" \
  --arg sha "$sha" \
  --arg branch "$branch" \
  '{message: $message, content: ($content | @base64)}
   + (if $sha != "" then {sha: $sha} else {} end)
   + (if $branch != "" then {branch: $branch} else {} end)')

printf '%s' "$body" | gh "${gh_args[@]}"
