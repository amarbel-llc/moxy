#!/usr/bin/env bash
set -euo pipefail

run_id="${1:-}"
repo_owner_name="${2:-}"
if [ -z "$run_id" ]; then
  echo "usage: ci-run-get <run_id> [<repo_owner_name>]" >&2
  exit 2
fi

# shellcheck source=bin/.resolve-repo
. "$(dirname "$0")/.resolve-repo"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  repo=$(resolve_repo_from_origin)
fi

run_json=$(gh api "repos/$repo/actions/runs/$run_id")
jobs_json=$(gh api "repos/$repo/actions/runs/$run_id/jobs" --jq '.jobs')

jq -n --argjson run "$run_json" --argjson jobs "$jobs_json" \
  '{run: $run, jobs: $jobs}'
