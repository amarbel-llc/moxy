#!/usr/bin/env bash
# Plugin monitor entrypoint for the gh-watch event watcher.
#
# Reads $dir/targets (one tab-separated target per line) and polls each
# target's live state every $GH_WATCH_INTERVAL seconds. Emits one stdout
# line per state transition. Completed runs are dropped from the targets
# file automatically. Stdout lines become Claude Code notifications.
#
# Target format:
#   <kind>\t<repo>\t<id>\t<handle>\t<added_ts>
#
# Kinds supported: run (Actions workflow run).
set -euo pipefail

dir="${MOXY_GH_WATCH_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/moxy/gh-watch}"
interval="${GH_WATCH_INTERVAL:-30}"
mkdir -p "$dir"
targets="$dir/targets"
[ -f "$targets" ] || : >"$targets"

count=$(wc -l <"$targets")
printf 'gh-watch connected: watching %s target(s) at %s (interval=%ss)\n' \
  "$count" "$dir" "$interval"

# In-memory state: keyed by handle → last "status/conclusion" tuple.
declare -A last_state

# Seed: emit a resume line per existing target so the agent sees current state.
while IFS=$'\t' read -r kind repo id handle added; do
  [ -z "$kind" ] && continue
  case "$kind" in
    run)
      t=$(gh api "repos/$repo/actions/runs/$id" \
        --jq '.status + "/" + (.conclusion // "null")' 2>/dev/null || echo "error/-")
      last_state["$handle"]="$t"
      printf 'resumed: %s %s\n' "$handle" "$t"
      ;;
    *)
      printf 'resumed: %s (unknown kind %s)\n' "$handle" "$kind"
      ;;
  esac
done <"$targets"

while true; do
  sleep "$interval"

  # Re-read to pick up new targets added via watch-run.
  tmp=$(mktemp "${targets}.XXXXXX")
  changed=0

  while IFS=$'\t' read -r kind repo id handle added; do
    [ -z "$kind" ] && continue
    case "$kind" in
      run)
        t=$(gh api "repos/$repo/actions/runs/$id" \
          --jq '.status + "/" + (.conclusion // "null") + "\t" + (.html_url // "")' 2>/dev/null || echo "error/-	")
        tuple="${t%%$'\t'*}"
        html_url="${t#*$'\t'}"
        prev="${last_state[$handle]:-unseen}"
        if [ "$tuple" != "$prev" ]; then
          printf 'run %s %s → %s\n' "$handle" "$prev" "$tuple"
          last_state["$handle"]="$tuple"
        fi
        status="${tuple%/*}"
        conclusion="${tuple#*/}"
        if [ "$status" = "completed" ]; then
          printf 'run %s done: %s (%s)\n' "$handle" "$conclusion" "$html_url"
          unset 'last_state[$handle]'
          changed=1
          continue  # drop from tmp → no longer in targets file
        fi
        ;;
      *)
        # Unknown kind: keep as-is, no polling.
        ;;
    esac
    printf '%s\t%s\t%s\t%s\t%s\n' "$kind" "$repo" "$id" "$handle" "$added" >>"$tmp"
  done <"$targets"

  if [ "$changed" = "1" ]; then
    mv "$tmp" "$targets"
  else
    rm -f "$tmp"
  fi
done
