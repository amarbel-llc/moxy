#!/usr/bin/env bash
set -euo pipefail
path="${1:-.}"
ref="${2:-}"
repo_owner_name="${3:-}"

if [ -n "$repo_owner_name" ]; then
  if [[ "$repo_owner_name" != */* ]]; then
    echo "ERROR: repo_owner_name must be in OWNER/NAME format" >&2
    exit 2
  fi
  repo="$repo_owner_name"
else
  user=$(gh api /user --jq '.login')
  name=$(gh repo view --json name --jq '.name')
  repo="$user/$name"
fi

gh_args=(api "repos/$repo/contents/$path")
[ -n "$ref" ] && gh_args+=(-f ref="$ref")

raw=$(gh "${gh_args[@]}")

# Detect if response is a file (object) or directory (array)
kind=$(printf '%s' "$raw" | jq -r 'if type == "array" then "dir" else .type // "file" end')

if [ "$kind" = "dir" ]; then
  printf '%s' "$raw" | jq '[.[] | {name, type, size, path}]'
else
  # File: decode base64 content
  printf '%s' "$raw" | jq -r '.content' | tr -d '\n' | base64 -d
fi
