#!/usr/bin/env bash
set -euo pipefail
repo=$(gh repo view --json nameWithOwner -q '.nameWithOwner')
base="$1"
head="$2"
per_page="${3:-30}"
page="${4:-1}"
gh api "repos/$repo/compare/$base...$head" \
  -f per_page="$per_page" \
  -f page="$page" \
  | jq '{
    status: .status,
    ahead_by: .ahead_by,
    behind_by: .behind_by,
    total_commits: .total_commits,
    commits: [.commits[] | {sha: .sha[0:7], message: (.commit.message | split("\n")[0]), author: .commit.author.name, date: .commit.author.date}],
    files: [.files[] | {filename: .filename, status: .status, additions: .additions, deletions: .deletions, changes: .changes}]
  }'
