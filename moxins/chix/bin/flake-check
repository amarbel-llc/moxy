#!/usr/bin/env bash
set -euo pipefail
flake_ref="${1:-.}"
flake_dir="${2:-.}"
keep_going="${3:-true}"

cd "$flake_dir"
nix_args=(flake check)
if [ "$keep_going" = "true" ]; then
  nix_args+=(--keep-going)
fi
nix_args+=(--flake "$flake_ref")

# nix flake check writes evaluation status (and warnings) to stderr; merge
# into stdout so the MCP result includes them.
output=$(nix "${nix_args[@]}" 2>&1) || { echo "$output"; exit 1; }

echo "$output"
