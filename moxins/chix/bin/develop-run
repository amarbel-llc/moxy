#!/usr/bin/env bash
set -euo pipefail
commands_json="$1"
flake_ref="${2:-.}"
flake_dir="${3:-.}"

cd "$flake_dir"

stderr_file=$(mktemp)
trap 'rm -f "$stderr_file"' EXIT

count=$(printf '%s' "$commands_json" | jq 'length')
for ((i=0; i<count; i++)); do
  cmd=$(printf '%s' "$commands_json" | jq -r ".[$i].command")
  mapfile -t cmd_args < <(printf '%s' "$commands_json" | jq -r ".[$i].args // [] | .[]")

  nix_args=(develop "$flake_ref" -c "$cmd")
  if [ ${#cmd_args[@]} -gt 0 ]; then
    nix_args+=("${cmd_args[@]}")
  fi

  if ! nix "${nix_args[@]}" 2>"$stderr_file"; then
    cat "$stderr_file"
    exit 1
  fi
done
