#!/usr/bin/env bash
set -euo pipefail
expr="${1:-}"
installable="${2:-}"
apply="${3:-}"
flake_dir="${4:-.}"

cd "$flake_dir"
nix_args=(eval --json)
if [ -n "$expr" ]; then
  nix_args+=(--expr "$expr")
elif [ -n "$installable" ]; then
  nix_args+=("$installable")
else
  nix_args+=(".#default")
fi
if [ -n "$apply" ]; then
  nix_args+=(--apply "$apply")
fi

stderr_file=$(mktemp)
trap 'rm -f "$stderr_file"' EXIT
output=$(nix "${nix_args[@]}" 2>"$stderr_file") || { cat "$stderr_file"; echo "$output"; exit 1; }

echo "$output"
