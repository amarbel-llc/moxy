#!/usr/bin/env bash
set -euo pipefail
path="$1"

# Resolve symlinks and validate under /nix/store/
resolved=$(readlink -f "$path")
case "$resolved" in
  /nix/store/*) ;;
  *) echo "Error: path must be under /nix/store/, got: $resolved" >&2; exit 1 ;;
esac

if [ ! -f "$resolved" ]; then
  echo "Error: not a regular file: $resolved" >&2
  exit 1
fi

cat "$resolved"
