#!/usr/bin/env bash
set -euo pipefail
installable="${1:-.#default}"
flake_dir="${2:-.}"
print_build_logs="${3:-true}"

cd "$flake_dir"
nix_args=(build --json --print-out-paths)
if [ "$print_build_logs" = "true" ]; then
  nix_args+=(-L)
fi
nix_args+=("$installable")

stderr_file=$(mktemp)
trap 'rm -f "$stderr_file"' EXIT
output=$(nix "${nix_args[@]}" 2>"$stderr_file") || { cat "$stderr_file"; echo "$output"; exit 1; }

echo "$output"
