#!/usr/bin/env bash
set -euo pipefail
installable="${1:-.#default}"
args_json="${2:-}"
flake_dir="${3:-.}"

cd "$flake_dir"
nix_args=(run "$installable")
if [ -n "$args_json" ] && [ "$args_json" != "null" ] && [ "$args_json" != "[]" ]; then
  nix_args+=(--)
  while IFS= read -r arg; do
    nix_args+=("$arg")
  done < <(printf '%s' "$args_json" | jq -r '.[]')
fi

nix "${nix_args[@]}"
