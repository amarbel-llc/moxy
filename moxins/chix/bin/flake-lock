#!/usr/bin/env bash
set -euo pipefail
flake_ref="${1:-.}"
update_inputs_json="${2:-}"
override_inputs_json="${3:-}"
flake_dir="${4:-.}"
head_n="${5:-}"
tail_n="${6:-}"
max_bytes="${7:-}"

cd "$flake_dir"
nix_args=(flake lock)

if [ -n "$update_inputs_json" ] && [ "$update_inputs_json" != "null" ] && [ "$update_inputs_json" != "[]" ]; then
  while IFS= read -r inp; do
    nix_args+=(--update-input "$inp")
  done < <(printf '%s' "$update_inputs_json" | jq -r '.[]')
fi

if [ -n "$override_inputs_json" ] && [ "$override_inputs_json" != "null" ] && [ "$override_inputs_json" != "{}" ]; then
  while IFS=$'\t' read -r key val; do
    nix_args+=(--override-input "$key" "$val")
  done < <(printf '%s' "$override_inputs_json" | jq -r 'to_entries[] | [.key, (.value | tostring)] | @tsv')
fi

nix_args+=(--flake "$flake_ref")

# nix flake lock writes progress to stderr; merge into stdout so MCP
# surfaces the message "warning: updating lock file ...".
output=$(nix "${nix_args[@]}" 2>&1) || { echo "$output"; exit 1; }

if [ -n "$tail_n" ]; then
  echo "$output" | tail -n "$tail_n"
elif [ -n "$head_n" ]; then
  echo "$output" | head -n "$head_n"
elif [ -n "$max_bytes" ]; then
  echo "$output" | head -c "$max_bytes"
else
  echo "$output"
fi
