#!/usr/bin/env bash
set -euo pipefail
flake_ref="${1:-.}"
inputs_json="${2:-}"
flake_dir="${3:-.}"
head_n="${4:-}"
tail_n="${5:-}"
max_bytes="${6:-}"

cd "$flake_dir"
nix_args=(flake update)

if [ -n "$inputs_json" ] && [ "$inputs_json" != "null" ] && [ "$inputs_json" != "[]" ]; then
  while IFS= read -r inp; do
    nix_args+=("$inp")
  done < <(printf '%s' "$inputs_json" | jq -r '.[]')
fi

nix_args+=("$flake_ref")

stderr_file=$(mktemp)
trap 'rm -f "$stderr_file"' EXIT
output=$(nix "${nix_args[@]}" 2>"$stderr_file") || { cat "$stderr_file"; echo "$output"; exit 1; }

if [ -n "$tail_n" ]; then
  echo "$output" | tail -n "$tail_n"
elif [ -n "$head_n" ]; then
  echo "$output" | head -n "$head_n"
elif [ -n "$max_bytes" ]; then
  echo "$output" | head -c "$max_bytes"
else
  echo "$output"
fi
