#!/usr/bin/env bash
set -euo pipefail
path="$1"
closure="${2:-false}"
derivation="${3:-false}"

nix_args=(path-info --json)
if [ "$closure" = "true" ]; then
  nix_args+=(--closure-size)
fi
if [ "$derivation" = "true" ]; then
  nix_args+=(--derivation)
fi
nix_args+=("$path")

stderr_file=$(mktemp)
trap 'rm -f "$stderr_file"' EXIT
output=$(nix "${nix_args[@]}" 2>"$stderr_file") || {
  stderr=$(cat "$stderr_file")
  # Check for the common case where a store path doesn't exist locally
  if echo "$stderr" | grep -q "does not exist"; then
    echo "Error: path not found in local store. If this is an installable (e.g., 'nixpkgs#hello'), try building it first with the build tool." >&2
    echo "$stderr" >&2
  else
    echo "$stderr" >&2
    echo "$output"
  fi
  exit 1
}
echo "$output"
