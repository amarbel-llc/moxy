#!/usr/bin/env bash
set -euo pipefail
packages="${1:-./...}"
output="${2:-}"
tags="${3:-}"
ldflags="${4:-}"
race="${5:-false}"
cwd="${6:-}"

if [ -n "$cwd" ]; then
  cd "$cwd"
fi

args=(build)
if [ "$race" = "true" ]; then
  args+=(-race)
fi
# Default output to /dev/null so go-build doubles as a compile check
# without leaving a binary in the caller's CWD. Pass `output` explicitly
# to keep the built artifact.
if [ -z "$output" ]; then
  output="/dev/null"
fi
args+=(-o "$output")
if [ -n "$tags" ]; then
  args+=(-tags "$tags")
fi
if [ -n "$ldflags" ]; then
  args+=(-ldflags "$ldflags")
fi
args+=("$packages")

go "${args[@]}"
