#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
source="$1"
destination="$2"
recursive="${3:-false}"
assert_within_cwd "$source"
assert_within_cwd "$destination"
mkdir -p "$(dirname "$destination")"

flags=()
[[ "$recursive" == "true" ]] && flags+=(-r)

cp "${flags[@]}" -- "$source" "$destination"
echo "Copied $source -> $destination"
