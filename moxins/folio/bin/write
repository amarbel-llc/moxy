#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
file="$1"
content="$2"
assert_within_cwd "$file"

# Create parent directories
mkdir -p "$(dirname "$file")"

# Atomic write via tempfile + rename
tmp=$(mktemp "$(dirname "$file")/.folio-write-XXXXXX")
trap 'rm -f "$tmp"' EXIT

printf '%s' "$content" > "$tmp"

# Preserve permissions of existing file
if [ -f "$file" ]; then
  chmod --reference="$file" "$tmp" 2>/dev/null || true
else
  chmod 644 "$tmp"
fi

mv "$tmp" "$file"
trap - EXIT
echo "Wrote $(printf '%s' "$content" | wc -c) bytes to $file"
