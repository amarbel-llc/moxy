#!/usr/bin/env bash
# Dynamic-perms gate for folio file ops.
# Usage: folio-perms <op> <path1> [<path2>...]
#
# Op values:
#   read         — apply read policy to every positional (one path per slot)
#   write        — apply write policy to every positional (one path per slot)
#   rm           — like write, but each positional is a possibly-space-
#                  separated path list that is split before checking
#                  (mirrors folio.rm's `paths` input shape)
#   copy|move    — apply read policy to $2 (source), write policy to $3 (dest)
#   link         — apply read policy to $2 (source), write policy to $3 (target)
#
# Policy:
#   - Path inside CWD                              → allow (read or write)
#   - /dev/fd/* (result-URI substitution pipe)     → allow
#   - madder://blobs/<digest> (cached tool result) → allow
#   - Path inside /nix/store                       → allow read; deny write
#   - Path inside a sibling repo of this repo       → allow read
#     (i.e. under the parent of this repo's MAIN worktree, but NOT the
#      main worktree itself; lets cross-repo reads of sibling checkouts
#      pass while the main checkout still prompts)
#   - Path inside Claude-native read dirs          → allow read
#   - Path inside Claude-native write-allow dirs   → allow write
#   - Anywhere else                                → ask
#
# Exit codes (per moxy native dynamic-perms contract):
#   0 = allow
#   1 = ask
#   2 = deny

set -euo pipefail

op="${1:-}"
shift || true
if [ -z "$op" ]; then
  echo "folio-perms: op (read|write|rm|copy|move|link) required" >&2
  exit 2
fi

# Capture every invocation so we can investigate odd reasons (e.g. paths
# that resolve to '//' or empty strings) after the fact. Best-effort: any
# error here is swallowed via `|| true`. Disable with FOLIO_PERMS_TRACE=0.
if [ "${FOLIO_PERMS_TRACE:-1}" != "0" ]; then
  trace_dir="${HOME:-/tmp}/.local/log/moxy"
  mkdir -p "$trace_dir" 2>/dev/null || true
  trace_file="$trace_dir/folio-perms.trace"
  {
    printf 'ts=%s pid=%s op=%s pwd=%s argc=%s\n' \
      "$(date -u +%FT%TZ)" "$$" "$op" "${PWD:-?}" "$#"
    i=1
    for a in "$@"; do
      printf '  argv[%d]=<%s>\n' "$i" "$a"
      i=$((i + 1))
    done
  } >>"$trace_file" 2>/dev/null || true
fi

cwd_real=$(realpath -m -- "${PWD}")
home_real=$(realpath -m -- "${HOME:-/}")
uid="${UID:-$(id -u)}"
session_tmp="${CLAUDE_CODE_TMPDIR:-}"
[ -n "$session_tmp" ] && session_tmp=$(realpath -m -- "$session_tmp")

# Read-allowed: any read inside any of these passes without prompting.
# Includes the umbrella ~/.claude tree so historical sessions, config,
# memory, plans, agents, hooks, etc. are all readable.
read_dirs=(
  "$cwd_real"
  "/nix/store"
  "${home_real}/.claude"
  "/tmp/claude-${uid}"
  "${home_real}/.local/log/moxy"
)
[ -n "$session_tmp" ] && read_dirs+=("$session_tmp")

# Sibling repos: resolve the current repo's MAIN worktree from the CWD (this
# works whether the CWD is the main checkout or a linked/spinclass worktree —
# `--git-common-dir` always points at the shared `<main>/.git`). Reads under
# the main worktree's PARENT directory are then auto-allowed, EXCEPT reads
# inside the main worktree itself: cross-repo reads of sibling checkouts pass
# without prompting, while the current repo's main checkout still prompts
# (work happens in the worktree, which is already read-allowed via CWD).
siblings_root=""
main_worktree=""
if git_common=$(git -C "$cwd_real" rev-parse --path-format=absolute \
  --git-common-dir 2>/dev/null) && [ -n "$git_common" ]; then
  main_worktree=$(realpath -m -- "$(dirname -- "$git_common")")
  siblings_root=$(dirname -- "$main_worktree")
fi

# Write-allowed: writes inside any of these pass without prompting.
# Reads still pass via read_dirs.
write_dirs=(
  "$cwd_real"
  "${home_real}/.claude/plans"
  "${home_real}/.claude/projects"
  "/tmp/claude-${uid}"
)
[ -n "$session_tmp" ] && write_dirs+=("$session_tmp")

# Deny-on-write: any write into these is rejected outright (not prompted).
# /nix/store is immutable; trying to write to it is a category error.
deny_write_dirs=(
  "/nix/store"
)

within_dir() {
  local p="$1" dir="$2"
  [ -z "$dir" ] && return 1
  case "$p" in
    "$dir"|"$dir"/*) return 0 ;;
  esac
  return 1
}

within_any() {
  local p="$1"
  shift
  for dir in "$@"; do
    [ -z "$dir" ] && continue
    if within_dir "$p" "$dir"; then return 0; fi
  done
  return 1
}

# True when $1 is inside a sibling repo: under the current repo's main-worktree
# parent, but not inside the main worktree itself. No-op when CWD isn't a repo.
within_sibling_repo() {
  local p="$1"
  [ -n "$siblings_root" ] || return 1
  within_dir "$p" "$siblings_root" || return 1
  within_dir "$p" "$main_worktree" && return 1
  return 0
}

resolve() {
  local p="$1"
  case "$p" in
    /dev/fd/*|madder://blobs/*) echo "$p"; return ;;
  esac
  # Resolve the parent directory canonically but do NOT follow a symlink at
  # the leaf itself. A `result -> /nix/store/...` symlink in the worktree is
  # located *in the CWD*, so it should be treated as a CWD path for policy.
  # Only its target is in /nix/store — the symlink entry itself is not.
  local parent leaf resolved_parent
  parent=$(dirname -- "$p")
  leaf=$(basename -- "$p")
  resolved_parent=$(realpath -m -- "$parent")
  echo "${resolved_parent}/${leaf}"
}

check_read() {
  local p="$1"
  case "$p" in
    /dev/fd/*|madder://blobs/*) return 0 ;;
  esac
  local resolved
  resolved=$(resolve "$p")
  if within_any "$resolved" "${read_dirs[@]}"; then
    return 0
  fi
  if within_sibling_repo "$resolved"; then
    return 0
  fi
  echo "$p resolves outside CWD/nix store/Claude/sibling-repo dirs — confirmation required for read"
  exit 1
}

check_write() {
  local p="$1"
  case "$p" in
    /dev/fd/*|madder://blobs/*) return 0 ;;
  esac
  local resolved
  resolved=$(resolve "$p")
  if within_any "$resolved" "${deny_write_dirs[@]}"; then
    echo "$p is in /nix/store (immutable) — refusing write"
    exit 2
  fi
  if within_any "$resolved" "${write_dirs[@]}"; then
    return 0
  fi
  echo "$p resolves outside CWD/Claude write-allow dirs — confirmation required for write"
  exit 1
}

case "$op" in
  read)
    for path in "$@"; do
      [ -n "$path" ] && check_read "$path"
    done
    echo "all paths inside read-allowed dirs — auto-allowed"
    exit 0
    ;;
  write)
    # Each positional is exactly one path. Do NOT whitespace-split — that
    # behavior belongs to the `rm` op below. This keeps file content that
    # may leak through as a trailing positional from being treated as a
    # list of paths.
    for p in "$@"; do
      [ -n "$p" ] && check_write "$p"
    done
    echo "all paths inside write-allowed dirs — auto-allowed"
    exit 0
    ;;
  rm)
    # `paths` arg in folio.rm is a single space-separated string. Split
    # on whitespace so each path gets independently checked.
    for blob in "$@"; do
      [ -z "$blob" ] && continue
      # shellcheck disable=SC2206
      pieces=($blob)
      for p in "${pieces[@]}"; do
        [ -n "$p" ] && check_write "$p"
      done
    done
    echo "all paths inside write-allowed dirs — auto-allowed"
    exit 0
    ;;
  copy|move|link)
    [ -n "${1:-}" ] && check_read "$1"
    [ -n "${2:-}" ] && check_write "$2"
    echo "$op auto-allowed: source readable, dest writable"
    exit 0
    ;;
  *)
    echo "folio-perms: unknown op '$op' (want read|write|rm|copy|move|link)" >&2
    exit 2
    ;;
esac
