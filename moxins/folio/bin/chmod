#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
path="$1"
mode="$2"
assert_within_cwd "$path"

if [ ! -e "$path" ] && [ ! -L "$path" ]; then
  echo "no such file or directory: $path" >&2
  exit 1
fi

chmod "$mode" -- "$path"
echo "chmod $mode $path"
