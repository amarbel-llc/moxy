#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
file="$1"; ds="$2"; de="$3"
assert_within_cwd "$file"
awk -v ds="$ds" -v de="$de" '!(NR>=ds && NR<=de){printf "%6d\\t%s\\n", NR, $0}' "$file"
