#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
file="$1"; start="$2"; end="$3"
assert_within_cwd "$file"
awk -v s="$start" -v e="$end" 'NR>=s && NR<=e{printf "%6d\t%s\n", NR, $0} NR>e{exit}' "$file"
