#!/usr/bin/env bash
set -euo pipefail
paths="$1"
force="${2:-false}"
recursive="${3:-false}"

flags=()
[[ "$force" == "true" ]] && flags+=(-f)
[[ "$recursive" == "true" ]] && flags+=(-r)

removed=()
for p in $paths; do
  rm "${flags[@]}" -- "$p"
  removed+=("$p")
done

echo "Removed ${#removed[@]} path(s): ${removed[*]}"
