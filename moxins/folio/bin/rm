#!/usr/bin/env bash
set -euo pipefail
assert_within_cwd() {
  case "$1" in /dev/fd/*) return ;; esac
  local resolved cwd
  resolved=$(realpath -m "$1")
  cwd=$(realpath -m "$PWD")
  case "$resolved" in
    "$cwd"|"$cwd"/*) ;;
    *) echo "path '$1' is outside CWD ($cwd). Use folio-external instead." >&2; exit 1 ;;
  esac
}
paths="$1"
force="${2:-false}"
recursive="${3:-false}"

flags=()
[[ "$force" == "true" ]] && flags+=(-f)
[[ "$recursive" == "true" ]] && flags+=(-r)

removed=()
for p in $paths; do
  assert_within_cwd "$p"
  rm "${flags[@]}" -- "$p"
  removed+=("$p")
done

echo "Removed ${#removed[@]} path(s): ${removed[*]}"
