#!/usr/bin/env bash
set -euo pipefail
repo="$1"
if [[ "$repo" != */* ]]; then
  owner=$(gh repo view --json owner -q '.owner.login')
  repo="$owner/$repo"
fi
path="${2:-.}"
ref="${3:-}"

gh_args=(api "repos/$repo/contents/$path")
[ -n "$ref" ] && gh_args+=(-f ref="$ref")

raw=$(gh "${gh_args[@]}")

# Detect if response is a file (object) or directory (array)
kind=$(printf '%s' "$raw" | jq -r 'if type == "array" then "dir" else .type // "file" end')

if [ "$kind" = "dir" ]; then
  printf '%s' "$raw" | jq '[.[] | {name, type, size, path}]'
else
  # File: decode base64 content
  printf '%s' "$raw" | jq -r '.content' | tr -d '\n' | base64 -d
fi
