#!/usr/bin/env bash
set -euo pipefail
repo="$1"
if [[ "$repo" != */* ]]; then
  owner=$(gh repo view --json owner -q '.owner.login')
  repo="$owner/$repo"
fi
ref="${2:-}"

# Default to the repo's default branch when no ref given
if [ -z "$ref" ]; then
  ref=$(gh api "repos/$repo" --jq '.default_branch')
fi

# Resolve ref to tree SHA via commits endpoint
tree_sha=$(gh api "repos/$repo/commits/$ref" --jq '.commit.tree.sha')

gh api "repos/$repo/git/trees/$tree_sha?recursive=1" \
  | jq '[.tree[] | {path, type, size}]'
