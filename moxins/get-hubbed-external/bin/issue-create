#!/usr/bin/env bash
set -euo pipefail
repo="$1"
if [[ "$repo" != */* ]]; then
  owner=$(gh repo view --json owner -q '.owner.login')
  repo="$owner/$repo"
fi
title="$2"
body="${3:-}"
labels_json="${4:-}"
gh_args=(issue create -R "$repo" --title "$title")

[ -n "$body" ] && gh_args+=(--body "$body")
if [ -n "$labels_json" ] && [ "$labels_json" != "null" ]; then
  while IFS= read -r label; do
    gh_args+=(--label "$label")
  done < <(printf '%s' "$labels_json" | jq -r '.[]')
fi
gh "${gh_args[@]}"
