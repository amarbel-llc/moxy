#!/usr/bin/env bash
set -euo pipefail
repo="$1"
if [[ "$repo" != */* ]]; then
  owner=$(gh repo view --json owner -q '.owner.login')
  repo="$owner/$repo"
fi
state="${2:-open}"
labels_json="${3:-}"
assignee="${4:-}"
milestone="${5:-}"
search="${6:-}"
limit="${7:-30}"
output_format="${8:-json}"
gh_args=(issue list -R "$repo" --state "$state" --limit "$limit" --json number,title,state,labels,assignees,milestone,createdAt,updatedAt)

if [ -n "$labels_json" ] && [ "$labels_json" != "null" ]; then
  label_csv=$(printf '%s' "$labels_json" | jq -r 'join(",")')
  gh_args+=(--label "$label_csv")
fi

[ -n "$assignee" ] && gh_args+=(--assignee "$assignee")

[ -n "$milestone" ] && gh_args+=(--milestone "$milestone")

[ -n "$search" ] && gh_args+=(--search "$search")
raw=$(gh "${gh_args[@]}")

if [ "$output_format" = "text" ]; then
  mime="text/plain"
  text=$(printf '%s' "$raw" | jq -r '.[] | "#\\(.number)\\t\\(.state)\\t\\(.title)\\t\\([.labels[].name] | join(","))"' | column -t -s $'\\t')
else
  mime="application/json"
  text=$(printf '%s' "$raw" | jq '[.[] | {
    number: .number,
    title: .title,
    state: .state,
    labels: [.labels[].name],
    assignees: [.assignees[].login],
    milestone: .milestone.title,
    created: .createdAt,
    updated: .updatedAt
  }]')
fi

jq -cn --arg text "$text" --arg mime "$mime" \
  '{content:[{type:"text",text:$text,mimeType:$mime}]}'
