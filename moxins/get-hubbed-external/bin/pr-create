#!/usr/bin/env bash
set -euo pipefail
repo="$1"
if [[ "$repo" != */* ]]; then
  owner=$(gh repo view --json owner -q '.owner.login')
  repo="$owner/$repo"
fi
title="$2"
body="${3:-}"
base="${4:-}"
head="${5:-}"
draft="${6:-}"
labels_json="${7:-}"
gh_args=(pr create -R "$repo" --title "$title")

[ -n "$body" ] && gh_args+=(--body "$body")

[ -n "$base" ] && gh_args+=(--base "$base")

[ -n "$head" ] && gh_args+=(--head "$head")

[ "$draft" = "true" ] && gh_args+=(--draft)
if [ -n "$labels_json" ] && [ "$labels_json" != "null" ]; then
  while IFS= read -r label; do
    gh_args+=(--label "$label")
  done < <(printf '%s' "$labels_json" | jq -r '.[]')
fi
gh "${gh_args[@]}"
