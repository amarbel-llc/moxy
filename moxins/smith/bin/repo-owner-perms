#!/usr/bin/env bash
# Dynamic-perms gate for smith write tools. Allows when the resolved repo
# owner matches the fj-authenticated user or one of their orgs (#417,
# mirroring get-hubbed's repo-owner-perms); asks otherwise.
#
# Receives: $1 = repo (OWNER/NAME, may be empty), $2 = host (may be empty)
#
# Exit codes (per moxy native dynamic-perms contract):
#   0 = allow
#   1 = ask
set -euo pipefail

repo="${1:-}"
host="${2:-}"

# shellcheck source=bin/.fj-common
. "$(dirname "$0")/.fj-common"

# No explicit repo means fj resolves from the cwd's git remote,
# which is presumed to be the authenticated user's own repo.
if [ -z "$repo" ]; then
  echo "no explicit repo — auto-allowed (resolved from cwd)"
  exit 0
fi

owner="${repo%%/*}"

fj_base "$host"

# fj unconditionally inspects the cwd's git remote (#398); run whoami from
# a scratch dir so owner-less remotes don't crash and produce a false ask.
_fj_scratch_dir
self=$(cd "$_fj_scratch" && "${fj_cmd[@]}" whoami 2>/dev/null | awk 'END{print $NF}') || true

if [ -z "$self" ]; then
  echo "could not determine authenticated user — confirmation required"
  exit 1
fi

if [ "$self" = "$owner" ]; then
  echo "owner ($owner) matches authenticated user — auto-allowed"
  exit 0
fi

# fj has no native "list my orgs" subcommand; use the raw REST passthrough
# (fj api, #414) against Forgejo's GitHub-compatible /user/orgs endpoint.
# Org objects use "username" (not "login") in Forgejo's API shape.
orgs_json=$(cd "$_fj_scratch" && "${fj_cmd[@]}" api user/orgs 2>/dev/null) || true
if printf '%s' "$orgs_json" | jq -e --arg owner "$owner" 'any(.[]?; .username == $owner)' >/dev/null 2>&1; then
  echo "owner ($owner) is a member org — auto-allowed"
  exit 0
fi

echo "owner ($owner) is not the authenticated user ($self) or a member org — confirmation required"
exit 1
