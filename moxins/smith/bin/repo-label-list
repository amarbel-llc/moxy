#!/usr/bin/env bash
set -euo pipefail
repo="${1:-}"
host="${2:-}"
archived="${3:-}"

# shellcheck source=bin/.fj-common
. "$(dirname "$0")/.fj-common"

fj_base "$host"
fj_cmd+=(repo labels)
if [ -n "$repo" ]; then
  validate_repo "$repo"
  fj_cmd+=("$repo")
fi
fj_cmd+=(view)
if [ "$archived" = "true" ]; then
  fj_cmd+=(-a)
fi
fj_run "$repo" "$host"
