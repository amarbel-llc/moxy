#!/usr/bin/env bash
set -euo pipefail
number="$1"
view="${2:-body}"
repo="${3:-}"
host="${4:-}"

# shellcheck source=bin/.fj-common
. "$(dirname "$0")/.fj-common"

case "$view" in
body | comments | labels | diff | files | commits) ;;
*)
  echo "ERROR: view must be one of body, comments, labels, diff, files, commits" >&2
  exit 2
  ;;
esac

ref=$(qualify_ref "$number" "$repo")
fj_base "$host"
"${fj_cmd[@]}" pr view "$ref" "$view"
