#!/usr/bin/env bash
set -euo pipefail
repo="${1:-}"
host="${2:-}"
page="${3:-}"

# shellcheck source=bin/.fj-common
. "$(dirname "$0")/.fj-common"

fj_base "$host"
fj_cmd+=(tag list)
if [ -n "$page" ]; then
  fj_cmd+=(-p "$page")
fi
if [ -n "$repo" ]; then
  validate_repo "$repo"
  fj_cmd+=(-r "$repo")
fi
fj_run "$repo" "$host"
