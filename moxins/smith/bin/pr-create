#!/usr/bin/env bash
set -euo pipefail
title="${1:-}"
body="${2:-}"
base="${3:-}"
head="${4:-}"
autofill="${5:-false}"
repo="${6:-}"
host="${7:-}"

# shellcheck source=bin/.fj-common
. "$(dirname "$0")/.fj-common"

fj_base "$host"
fj_cmd+=(pr create)
if [ -n "$base" ]; then
  fj_cmd+=(--base "$base")
fi
if [ -n "$head" ]; then
  fj_cmd+=(--head "$head")
fi
if [ -n "$repo" ]; then
  validate_repo "$repo"
  fj_cmd+=(-r "$repo")
fi
if [ "$autofill" = "true" ]; then
  fj_cmd+=(-A)
else
  if [ -z "$title" ]; then
    echo "ERROR: title is required unless autofill is true" >&2
    exit 2
  fi
  # An explicit --body (even empty) keeps fj from opening an editor —
  # moxy tools run headless.
  fj_cmd+=(--body "$body" "$title")
fi
fj_run "$repo" "$host"
