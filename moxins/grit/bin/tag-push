#!/usr/bin/env bash
set -euo pipefail
name="$1"
remote="${2:-}"
delete="${3:-}"
force="${4:-}"
repo="${5:-.}"
cd "$repo"

[ -z "$remote" ] && remote="origin"

git_args=(push)
[ "$force" = "true" ] && git_args+=(--force)
git_args+=("$remote")

if [ "$delete" = "true" ]; then
  git_args+=(":refs/tags/$name")
else
  git_args+=("refs/tags/$name")
fi

git "${git_args[@]}"
