#!/usr/bin/env bash
set -euo pipefail
remote="${1:-}"
branch="${2:-}"
set_upstream="${3:-}"
force_with_lease="${4:-}"
force_if_includes="${5:-}"
repo="${6:-.}"
remote_branch="${7:-}"
lease_ref_sha="${8:-}"
cd "$repo"

git_args=(push)

if [ "$force_with_lease" = "true" ]; then
  # The destination ref is what a force push clobbers, so the main/master
  # guard keys off remote_branch when a refspec is used. Falls back to the
  # source branch (or the current branch) when pushing to a same-named ref.
  target="$remote_branch"
  if [ -z "$target" ]; then
    target="$branch"
    if [ -z "$target" ]; then
      target=$(git rev-parse --abbrev-ref HEAD)
    fi
  fi
  if [ "$target" = "HEAD" ]; then
    echo "ERROR: force push in detached HEAD state requires an explicit branch argument" >&2
    exit 1
  fi
  if [ "$target" = "main" ] || [ "$target" = "master" ]; then
    echo "ERROR: force push to main/master is blocked for safety" >&2
    exit 1
  fi

  if [ -n "$lease_ref_sha" ]; then
    # Explicit-value form: needed when there's no local remote-tracking ref
    # for $target (narrow fetch refspec, DWIM checkout, etc.) since the
    # boolean form has no local baseline to compare the remote against.
    # lease_target is deliberately the same value as the guard's $target —
    # both derive from the same remote_branch -> branch -> HEAD fallback —
    # but they are logically distinct: the guard only needs an approximate
    # name to catch main/master, while lease_target must be the exact ref
    # git compares against for --force-with-lease=<ref>:<sha>.
    lease_target="$target"
    git_args+=("--force-with-lease=${lease_target}:${lease_ref_sha}")
  else
    git_args+=(--force-with-lease)
  fi
fi

[ "$force_if_includes" = "true" ] && git_args+=(--force-if-includes)
[ "$set_upstream" = "true" ] && git_args+=(-u)

# Default remote to origin when a branch or refspec is specified, so git
# doesn't interpret the branch name as a remote.
if { [ -n "$branch" ] || [ -n "$remote_branch" ]; } && [ -z "$remote" ]; then
  remote="origin"
fi

[ -n "$remote" ] && git_args+=("$remote")
if [ -n "$remote_branch" ]; then
  # refspec form: <source>:<remote_branch>. Default the source to HEAD so
  # callers can do `git push origin HEAD:some-other-branch`.
  src="$branch"
  [ -z "$src" ] && src="HEAD"
  git_args+=("${src}:${remote_branch}")
elif [ -n "$branch" ]; then
  git_args+=("$branch")
fi
git "${git_args[@]}"
