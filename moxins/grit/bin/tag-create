#!/usr/bin/env bash
set -euo pipefail
name="$1"
message="${2:-}"
ref="${3:-}"
sign="${4:-}"
lightweight="${5:-}"
force="${6:-}"
repo="${7:-.}"
cd "$repo"

if [ "$lightweight" = "true" ]; then
  if [ -n "$message" ]; then
    echo "tag-create: lightweight tags cannot have a message" >&2
    exit 2
  fi
  if [ "$sign" = "true" ]; then
    echo "tag-create: lightweight tags cannot be signed" >&2
    exit 2
  fi
fi

git_args=(tag)
[ "$force" = "true" ] && git_args+=(-f)

if [ "$lightweight" != "true" ]; then
  if [ "$sign" = "false" ]; then
    git_args+=(-a)
  else
    git_args+=(-s)
  fi
  if [ -z "$message" ]; then
    echo "tag-create: message is required for annotated/signed tags" >&2
    exit 2
  fi
  git_args+=(-m "$message")
fi

git_args+=("$name")
[ -n "$ref" ] && git_args+=("$ref")

git "${git_args[@]}"
echo "Created tag $name"
