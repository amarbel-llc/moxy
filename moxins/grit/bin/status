#!/usr/bin/env bash
set -euo pipefail
paths_json="${1:-}"
untracked="${2:-}"
ignored="${3:-}"
repo="${4:-.}"
cd "$repo"

git_args=(status --short --branch)

case "$untracked" in
  no|normal|all) git_args+=(--untracked-files="$untracked") ;;
  "") : ;;
  *) echo "untracked must be no|normal|all" >&2; exit 2 ;;
esac

[ "$ignored" = "true" ] && git_args+=(--ignored)

if [ -n "$paths_json" ] && [ "$paths_json" != "null" ]; then
  git_args+=(--)
  # `paths` is declared as an array of strings, but a client may pass a bare
  # string (moxy unquotes JSON string values before they reach this script),
  # which is not valid JSON. Feeding such a value to `jq -r '.[]'` emitted a
  # cryptic "jq: parse error" while git still ran, because the failure was
  # swallowed by the process substitution (#303). Split a JSON array when the
  # value is one; otherwise treat the whole value as a single path filter.
  if printf '%s' "$paths_json" | jq -e 'type == "array"' >/dev/null 2>&1; then
    while IFS= read -r p; do
      git_args+=("$p")
    done < <(printf '%s' "$paths_json" | jq -r '.[]')
  else
    git_args+=("$paths_json")
  fi
fi

git "${git_args[@]}"
