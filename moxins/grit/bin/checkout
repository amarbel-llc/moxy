#!/usr/bin/env bash
set -euo pipefail
ref="${1:-}"
create="${2:-}"
paths_json="${3:-}"
ours="${4:-}"
theirs="${5:-}"
repo="${6:-.}"
cd "$repo"

git_args=(checkout)

if [ -n "$paths_json" ] && [ "$paths_json" != "null" ]; then
  # File restore mode

  [ "$ours" = "true" ] && git_args+=(--ours)

  [ "$theirs" = "true" ] && git_args+=(--theirs)

  [ -n "$ref" ] && git_args+=("$ref")
  git_args+=(--)
  # `paths` is declared as an array of strings, but a client may pass a bare
  # string (moxy unquotes JSON string values before they reach this script),
  # which is not valid JSON. Feeding such a value to `jq -r '.[]'` emitted a
  # cryptic "jq: parse error" while git still ran, because the failure was
  # swallowed by the process substitution (#307, same class as #303). Split a
  # JSON array when the value is one; otherwise treat it as a single path.
  if printf '%s' "$paths_json" | jq -e 'type == "array"' >/dev/null 2>&1; then
    while IFS= read -r p; do
      git_args+=("$p")
    done < <(printf '%s' "$paths_json" | jq -r '.[]')
  else
    git_args+=("$paths_json")
  fi
else
  # Branch switch mode

  [ "$create" = "true" ] && git_args+=(-b)

  [ -n "$ref" ] && git_args+=("$ref")
fi

git "${git_args[@]}"
