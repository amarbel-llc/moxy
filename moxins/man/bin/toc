#!/usr/bin/env bash
set -euo pipefail

page="$1"
src=$(man -w "$page" 2>/dev/null) || true
src="${src%%$'\n'*}"

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
raw=$(case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac)
# Extract section and subsection headings from raw roff source.
# Handles both mdoc(7) (.Sh/.Ss) and man(7) (.SH/.SS) macros.
awk '/^\.(Sh|SH) /{sub(/^\.(Sh|SH) /,""); gsub(/^"|"$/,""); print "# "$0}
     /^\.(Ss|SS) /{sub(/^\.(Ss|SS) /,""); gsub(/^"|"$/,""); print "## "$0}' <<< "$raw"
