#!/usr/bin/env bash
set -euo pipefail

page="$1"; section_name="$2"
src=$(man -w "$page" 2>/dev/null) || true
src="${src%%$'\n'*}"

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
raw=$(case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac)
# pandoc reads groff man macros directly; mandoc -T man converts mdoc→man first
rendered=$(echo "$raw" | pandoc -f man -t markdown 2>/dev/null)
if ! grep -q '^#' <<< "$rendered"; then
  rendered=$(echo "$raw" | mandoc -T man 2>/dev/null | pandoc -f man -t markdown 2>/dev/null)
fi
result=$(awk -v target="$section_name" '
BEGIN { found=0; IGNORECASE=1 }
/^#+ / {
  if (found) exit
  name = $0; sub(/^#+ /, "", name)
  if (tolower(name) == tolower(target)) found=1
}
found { print }
' <<< "$rendered") || true
if [ -z "$result" ]; then
  echo "Section \"$section_name\" not found in $page. Available sections:"
  awk '/^#+ /{print}' <<< "$rendered"
  exit 1
fi
echo "$result"
