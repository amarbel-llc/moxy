#!/usr/bin/env bash
set -euo pipefail

page="$1"; section_name="$2"
src=$(man -w "$page" 2>/dev/null) || true
src="${src%%$'\n'*}"

[ -z "$src" ] && { echo "No manual entry for $page"; exit 1; }
raw=$(case "$src" in
  *.gz) gzip -dc "$src" ;;
  *)    cat "$src" ;;
esac)
# Extract a section by name from raw roff source.
# Handles both mdoc(7) (.Sh) and man(7) (.SH) section macros.
result=$(awk -v target="$section_name" '
BEGIN { found=0; IGNORECASE=1 }
/^\.(Sh|SH) / {
  if (found) exit
  name = $0; sub(/^\.(Sh|SH) /, "", name)
  gsub(/^"|"$/, "", name)
  if (tolower(name) == tolower(target)) found=1
}
found { print }
' <<< "$raw") || true
if [ -z "$result" ]; then
  echo "Section \"$section_name\" not found in $page. Available sections:"
  awk '/^\.(Sh|SH) /{sub(/^\.(Sh|SH) /,""); gsub(/^"|"$/,""); print}' <<< "$raw"
  exit 1
fi
echo "$result"
