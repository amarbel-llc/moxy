#!/usr/bin/env python3

import os
import sys
from pathlib import Path


def main():
    if len(sys.argv) < 2:
        print("Usage: freud-transcript <session_id>", file=sys.stderr)
        sys.exit(1)

    session_id = sys.argv[1]
    projects_dir = Path(os.environ.get("CLAUDE_PROJECTS_DIR", Path.home() / ".claude" / "projects"))

    if not projects_dir.is_dir():
        print("No projects directory found")
        sys.exit(1)

    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir():
            continue
        f = proj_dir / f"{session_id}.jsonl"
        if f.exists():
            sys.stdout.write(f.read_text())
            return

    print(f"Session {session_id} not found. Use the sessions tool to discover available session ids.")
    sys.exit(1)


if __name__ == "__main__":
    main()
