#!/usr/bin/env python3

import json
import os
import sys
from pathlib import Path

RESULT_TRUNCATE = 200


def find_session(session_id: str) -> Path | None:
    projects_dir = Path(os.environ.get(
        "CLAUDE_PROJECTS_DIR", Path.home() / ".claude" / "projects"
    ))
    if not projects_dir.is_dir():
        return None
    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir():
            continue
        f = proj_dir / f"{session_id}.jsonl"
        if f.exists():
            return f
    return None


def oneline(s: str) -> str:
    return s.replace("\n", " ").strip()


def truncate(s: str, n: int = RESULT_TRUNCATE) -> str:
    s = oneline(s)
    if len(s) <= n:
        return s
    return s[:n] + "..."


def main():
    session_id = sys.argv[1] if len(sys.argv) > 1 else ""
    tool_name_filter = (sys.argv[2] if len(sys.argv) > 2 else "").lower()
    limit = int(sys.argv[3]) if len(sys.argv) > 3 and sys.argv[3] else 0
    include_results = (sys.argv[4] if len(sys.argv) > 4 else "").lower() in ("true", "1", "yes")

    if not session_id:
        print("Usage: freud-tool-usage <session_id> [tool_name] [limit] [include_results]",
              file=sys.stderr)
        sys.exit(1)

    path = find_session(session_id)
    if path is None:
        print(f"Session {session_id} not found. Use the sessions tool to list available sessions.")
        sys.exit(1)

    # Single pass: collect tool calls and their results
    calls = []
    results_map: dict[str, dict] = {}  # tool_use_id -> {text, is_error}
    msg_index = 0

    with open(path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            msg_type = obj.get("type")
            if msg_type not in ("user", "assistant"):
                continue

            content = obj.get("message", {}).get("content")
            if not isinstance(content, list):
                msg_index += 1
                continue

            if msg_type == "assistant":
                for block in content:
                    if not isinstance(block, dict) or block.get("type") != "tool_use":
                        continue

                    tool_id = block.get("id", "")
                    name = block.get("name", "?")
                    input_data = block.get("input", {})

                    if tool_name_filter and tool_name_filter not in name.lower():
                        continue

                    calls.append({
                        "id": tool_id,
                        "name": name,
                        "input": input_data,
                        "msg_index": msg_index,
                    })

            elif msg_type == "user":
                for block in content:
                    if not isinstance(block, dict) or block.get("type") != "tool_result":
                        continue

                    tool_use_id = block.get("tool_use_id", "")
                    is_error = block.get("is_error", False)
                    inner = block.get("content", "")

                    if isinstance(inner, list):
                        text = " ".join(
                            b.get("text", "")
                            for b in inner
                            if isinstance(b, dict) and b.get("type") == "text"
                        )
                    elif isinstance(inner, str):
                        text = inner
                    else:
                        text = str(inner)

                    results_map[tool_use_id] = {
                        "text": text,
                        "is_error": is_error,
                    }

            msg_index += 1

    if limit > 0:
        calls = calls[:limit]

    lines = []
    for i, call in enumerate(calls, start=1):
        input_str = json.dumps(call["input"], separators=(",", ":"))
        lines.append(f"[{i}] msg:{call['msg_index']} {call['name']} \u2192 {oneline(input_str)}")

        if include_results:
            result = results_map.get(call["id"])
            if result:
                text = truncate(result["text"])
                if result["is_error"]:
                    lines.append(f"     \u21b3 ERROR: {text}")
                else:
                    lines.append(f"     \u21b3 {text}")
            else:
                lines.append(f"     \u21b3 (no result)")

    lines.append(f"\n{len(calls)} tool call(s)")

    emit_mcp_result("\n".join(lines))


def emit_mcp_result(text: str, mime: str = "text/plain"):
    result = {"content": [{"type": "text", "text": text, "mimeType": mime}]}
    print(json.dumps(result))


if __name__ == "__main__":
    main()
