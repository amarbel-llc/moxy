#!/usr/bin/env python3

import json
import os
import sys
import time
from collections import defaultdict
from datetime import datetime, timezone
from pathlib import Path


def resolve_cwd(proj_dir: Path) -> str | None:
    """Extract cwd from the newest JSONL in a project directory."""
    jsonls = sorted(proj_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not jsonls:
        return None

    with open(jsonls[0]) as f:
        for i, line in enumerate(f):
            if i >= 200:
                break
            try:
                obj = json.loads(line)
                cwd = obj.get("cwd")
                if cwd:
                    return cwd
            except (json.JSONDecodeError, KeyError):
                continue

    name = proj_dir.name.lstrip("-")
    return "/" + name.replace("-", "/") + " (heuristic)"


def matches_project(resolved_cwd: str, dir_name: str, filter_str: str) -> bool:
    lower = filter_str.lower()
    return lower in resolved_cwd.lower() or lower in dir_name.lower()


def find_session(session_id: str, projects_dir: Path) -> Path | None:
    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir():
            continue
        f = proj_dir / f"{session_id}.jsonl"
        if f.exists():
            return f
    return None


def extract_tool_names(path: Path) -> set[str]:
    """Extract unique tool names from a session JSONL."""
    tools: set[str] = set()
    with open(path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            if obj.get("type") != "assistant":
                continue

            content = obj.get("message", {}).get("content")
            if not isinstance(content, list):
                continue

            for block in content:
                if isinstance(block, dict) and block.get("type") == "tool_use":
                    name = block.get("name", "")
                    if name:
                        tools.add(name)
    return tools


def subagent_paths(session_path: Path) -> list[Path]:
    """Return subagent JSONL paths for a session, if any."""
    sub_dir = session_path.parent / session_path.stem / "subagents"
    if sub_dir.is_dir():
        return list(sub_dir.glob("*.jsonl"))
    return []


def tally_tools(path: Path, session_tools: set[str], total_calls: defaultdict[str, int]):
    """Extract tool names from a JSONL, adding to session_tools and total_calls."""
    with open(path) as f:
        for line in f:
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            if obj.get("type") != "assistant":
                continue

            content = obj.get("message", {}).get("content")
            if not isinstance(content, list):
                continue

            for block in content:
                if isinstance(block, dict) and block.get("type") == "tool_use":
                    name = block.get("name", "")
                    if name:
                        session_tools.add(name)
                        total_calls[name] += 1


def main():
    project_filter = sys.argv[1] if len(sys.argv) > 1 else ""
    days = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2] else 7
    session_ids_arg = sys.argv[3] if len(sys.argv) > 3 else ""
    scope = (sys.argv[4] if len(sys.argv) > 4 else "both").lower()
    if scope not in ("both", "main", "subagents"):
        scope = "both"

    projects_dir = Path(os.environ.get(
        "CLAUDE_PROJECTS_DIR", Path.home() / ".claude" / "projects"
    ))
    if not projects_dir.is_dir():
        return emit_mcp_result("(no sessions found)")

    session_paths: list[Path] = []

    if session_ids_arg:
        # Explicit session list mode
        for sid in session_ids_arg.split(","):
            sid = sid.strip()
            if not sid:
                continue
            path = find_session(sid, projects_dir)
            if path:
                session_paths.append(path)
        if not session_paths:
            return emit_mcp_result("No matching sessions found for the given IDs.")
    else:
        # Discovery mode: project + days filters
        cutoff = time.time() - (days * 86400)

        cwd_map: dict[str, str] = {}
        for proj_dir in sorted(projects_dir.iterdir()):
            if not proj_dir.is_dir():
                continue
            cwd = resolve_cwd(proj_dir)
            if cwd:
                cwd_map[proj_dir.name] = cwd

        for proj_dir in projects_dir.iterdir():
            if not proj_dir.is_dir() or proj_dir.name not in cwd_map:
                continue
            project = cwd_map[proj_dir.name]
            if project_filter and not matches_project(project, proj_dir.name, project_filter):
                continue
            for f in proj_dir.glob("*.jsonl"):
                if f.stat().st_mtime >= cutoff:
                    session_paths.append(f)

    if not session_paths:
        return emit_mcp_result(f"No sessions found (days={days}, project={project_filter or 'all'})")

    # Collect tools per session (including subagents)
    tool_sessions: defaultdict[str, int] = defaultdict(int)
    total_calls: defaultdict[str, int] = defaultdict(int)

    for path in session_paths:
        session_tools: set[str] = set()
        all_paths: list[Path] = []
        if scope in ("both", "main"):
            all_paths.append(path)
        if scope in ("both", "subagents"):
            all_paths.extend(subagent_paths(path))
        for p in all_paths:
            tally_tools(p, session_tools, total_calls)

        for name in session_tools:
            tool_sessions[name] += 1

    if not tool_sessions:
        return emit_mcp_result(f"No tool calls found across {len(session_paths)} sessions")

    # Sort by session count descending, then by total calls
    ranked = sorted(
        tool_sessions.keys(),
        key=lambda t: (tool_sessions[t], total_calls[t]),
        reverse=True,
    )

    # Format output
    lines = []
    mode = "explicit session list" if session_ids_arg else f"{days} days"
    proj_desc = f", project: {project_filter}" if project_filter else ""
    lines.append(f"Unique tools across {len(session_paths)} sessions ({mode}{proj_desc})")
    lines.append(f"{len(ranked)} unique tools, {sum(total_calls.values())} total calls")

    max_name = max(4, max(len(t) for t in ranked))
    max_sess = max(8, len(str(max(tool_sessions.values()))))
    max_calls = max(5, len(str(max(total_calls.values()))))

    lines.append("")
    lines.append(f"  {'#':>3}  {'Tool':<{max_name}}  {'Sessions':>{max_sess}}  {'Calls':>{max_calls}}")
    for i, tool in enumerate(ranked, start=1):
        lines.append(
            f"  {i:>3}  {tool:<{max_name}}  {tool_sessions[tool]:>{max_sess}}  {total_calls[tool]:>{max_calls}}"
        )

    # Date range
    mtimes = [p.stat().st_mtime for p in session_paths]
    earliest = datetime.fromtimestamp(min(mtimes), tz=timezone.utc).strftime("%Y-%m-%d")
    latest = datetime.fromtimestamp(max(mtimes), tz=timezone.utc).strftime("%Y-%m-%d")
    lines.append(f"\n{len(session_paths)} sessions analyzed ({earliest} \u2192 {latest})")

    emit_mcp_result("\n".join(lines))


def emit_mcp_result(text: str, mime: str = "text/plain"):
    result = {"content": [{"type": "text", "text": text, "mimeType": mime}]}
    print(json.dumps(result))


if __name__ == "__main__":
    main()
