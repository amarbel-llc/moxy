bats_timeout := "30"
# Prompt proxy tests need ~10s for child server startup + JSON-RPC round-trip;
# raised from 15 because high parallelism (--jobs num_cpus) can blow the margin.
# Halve job count vs. num_cpus() so child-server startup contention doesn't
# starve individual tests past their per-test timeout.
bats_jobs := `n=$(nproc 2>/dev/null || sysctl -n hw.ncpu); echo $((n / 2 > 0 ? n / 2 : 1))`

# This justfile is the in-tree iteration entrypoint for raw bats. The
# nix-sandbox lanes (`just test-bats`, `just test-bats-tag <tag>` at
# the repo root) are the canonical CI path; this exists for ad-hoc
# devshell runs against ./build/moxy. See top-level justfile's
# `test-bats-dev` recipe for the env-var setup the lane mirrors.

test-targets *targets="*.bats":
  BATS_TEST_TIMEOUT="{{bats_timeout}}" \
  PARALLEL_HOME="$(mktemp -d)" \
    bats --jobs {{bats_jobs}} {{targets}}

test-tags *tags:
  BATS_TEST_TIMEOUT="{{bats_timeout}}" \
  PARALLEL_HOME="$(mktemp -d)" \
    bats --jobs {{bats_jobs}} --filter-tags {{tags}} *.bats

test: (test-targets "*.bats")
